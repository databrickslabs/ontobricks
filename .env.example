# OntoBricks Environment Configuration
# Copy this file to .env and fill in your values
#
# NOTE: For Databricks Apps deployment, most of these are set automatically
# by the platform. This file is primarily for LOCAL development.

# ============================================================================
# Databricks Connection (Required for Local Development)
# ============================================================================
# Your Databricks workspace URL (e.g., https://your-workspace.cloud.databricks.com)
DATABRICKS_HOST=

# Personal Access Token for authentication
# Generate at: Databricks Workspace > User Settings > Developer > Access Tokens
DATABRICKS_TOKEN=

# SQL Warehouse ID for query execution
# Find at: Databricks Workspace > SQL > SQL Warehouses > (select warehouse) > Connection details
DATABRICKS_SQL_WAREHOUSE_ID=

# ============================================================================
# Default Catalog/Schema (Optional)
# ============================================================================
# Default Unity Catalog for browsing tables
DATABRICKS_CATALOG=main

# Default schema within the catalog
DATABRICKS_SCHEMA=default

# ============================================================================
# MLflow Tracing (Optional)
# ============================================================================
# Send agent traces to your Databricks workspace instead of local mlflow.db.
# Requires DATABRICKS_HOST and DATABRICKS_TOKEN above.
MLFLOW_TRACKING_URI=databricks

# MLflow experiment name (default: ontobricks-agents)
# ONTOBRICKS_MLFLOW_EXPERIMENT=ontobricks-agents

# ============================================================================
# Application Settings (Optional)
# ============================================================================
# Secret key for session encryption (generate a secure random string)
# In production, use a strong random key
SECRET_KEY=your-secret-key-change-in-production

# Application port (default: 8000)
# Note: In Databricks Apps, this is set automatically via DATABRICKS_APP_PORT
# DATABRICKS_APP_PORT=8000

# ============================================================================
# Volume Path for Mapping Storage (Optional)
# ============================================================================
# Unity Catalog volume path for storing R2RML mappings
# Format: /Volumes/<catalog>/<schema>/<volume>
# VOLUME_PATH=/Volumes/main/ontobricks/mappings
